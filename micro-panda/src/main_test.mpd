import io::print_i32
import io::print_str
import io::print_bool
import io::print_float
import io::print_fixed
import io::println
import test::*

fun print_something()
    print_str("Hello, World!")
    println()
    print_i32(123)
    println()
    print_bool(true)
    println()
    print_float(3.14159, 2)
    println()
    print_fixed(-1.231, 2)
    println()
    val a: fixed = 3
    val b: fixed = 2
    print_fixed(a / b, 2)
    println()

@test
fun add_int()
    assert(1 + 2 == 3)

@test
fun sub_int()
    // check failed assertion is reported correctly
    assert(3 - 1 == 3)
