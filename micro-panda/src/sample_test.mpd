import test::*

@test
fun add_int()
    assert(1 + 2 == 3)

@test
fun sub_int()
    // check failed assertion is reported correctly
    assert(3 - 1 == 2)

@test
fun invalid_indentation()
    val x: i16 = 42
    val y: i16 = 42
    // check failed assertion is reported correctly, even when types don't match
    assert(x == y)
