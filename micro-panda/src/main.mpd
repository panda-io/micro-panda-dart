import console::print_i32
import console::print_str
import console::print_bool
import console::print_float
import console::print_fixed
import console::println
import test::*

fun main() i32
    print_str("Hello, Micro-Panda!")
    println()
    print_i32(123)
    println()
    print_bool(true)
    println()
    print_float(3.14159, 2)
    println()
    print_fixed(-1.231, 2)
    println()
    val a: fixed = 3
    val b: fixed = 2
    print_fixed(a / b, 2)
    println()

    return 0
