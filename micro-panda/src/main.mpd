import io::print_i32
import io::print_str
import io::print_bool
import io::print_f32
import io::print_fixed
import io::println

fun main() i32
    print_str("Hello, World!")
    println()
    print_i32(123)
    println()
    print_bool(true)
    println()
    print_f32(3.14159, 2)
    println()
    // print_fixed(1.231, 2)
    println()
    return 0