import test::assert
import memory::Allocator
import string::equals
import string::starts_with
import string::ends_with
import string::index_of
import string::sub
import string::trim_start
import string::trim_end
import string::trim
import string::token
import string::skip
import string::parse_u32
import string::parse_i32
import string::format_u32
import string::format_i32

@test
fun test_equals()
    assert(equals("hello", "hello"))
    assert(equals("", ""))
    assert(equals("hello", "world") == false)
    assert(equals("hello", "hell") == false)
    assert(equals("hell", "hello") == false)

@test
fun test_starts_with()
    assert(starts_with("hello world", "hello"))
    assert(starts_with("hello", "hello"))
    assert(starts_with("hello", "") )
    assert(starts_with("hello", "world") == false)
    assert(starts_with("hi", "hello") == false)

@test
fun test_ends_with()
    assert(ends_with("hello world", "world"))
    assert(ends_with("hello", "hello"))
    assert(ends_with("hello", ""))
    assert(ends_with("hello", "hell") == false)
    assert(ends_with("hi", "hello") == false)

@test
fun test_index_of()
    assert(index_of("hello", 101) == 1)   // 'e' = 101
    assert(index_of("hello", 104) == 0)   // 'h' = 104
    assert(index_of("hello", 111) == 4)   // 'o' = 111
    assert(index_of("hello", 120) == -1)  // 'x' = 120

@test
fun test_sub()
    val s := sub("hello world", 6, 5)
    assert(equals(s, "world"))
    val s2 := sub("hello", 0, 3)
    assert(equals(s2, "hel"))

@test
fun test_trim_start()
    assert(equals(trim_start("  hello"), "hello"))
    assert(equals(trim_start("hello"), "hello"))
    assert(equals(trim_start("   "), ""))

@test
fun test_trim_end()
    assert(equals(trim_end("hello  "), "hello"))
    assert(equals(trim_end("hello"), "hello"))
    assert(equals(trim_end("   "), ""))

@test
fun test_trim()
    assert(equals(trim("  hello  "), "hello"))
    assert(equals(trim("hello"), "hello"))
    assert(equals(trim("  "), ""))

@test
fun test_token()
    val s := "one,two,three"
    val t1 := token(s, 0, 44)         // ',' = 44
    assert(equals(t1, "one"))
    val pos1 := skip(s, t1.size(), 44)
    val t2 := token(s, pos1, 44)
    assert(equals(t2, "two"))
    val pos2 := skip(s, pos1 + t2.size(), 44)
    val t3 := token(s, pos2, 44)
    assert(equals(t3, "three"))

@test
fun test_parse_u32()
    assert(parse_u32("0") == 0)
    assert(parse_u32("42") == 42)
    assert(parse_u32("1234") == 1234)

@test
fun test_parse_i32()
    assert(parse_i32("42") == 42)
    assert(parse_i32("-42") == -42)
    assert(parse_i32("0") == 0)

@test
fun test_format_u32()
    var alloc: Allocator
    alloc.init(64)
    var buf := alloc.allocate_array<u8>(12)
    val n := format_u32(buf, 42)
    assert(n == 2)
    assert(equals(sub(buf, 0, n), "42"))
    val n2 := format_u32(buf, 0)
    assert(n2 == 1)
    assert(equals(sub(buf, 0, n2), "0"))

@test
fun test_format_i32()
    var alloc: Allocator
    alloc.init(64)
    var buf := alloc.allocate_array<u8>(12)
    val n := format_i32(buf, -42)
    assert(n == 3)
    assert(equals(sub(buf, 0, n), "-42"))
    val n2 := format_i32(buf, 100)
    assert(n2 == 3)
    assert(equals(sub(buf, 0, n2), "100"))
