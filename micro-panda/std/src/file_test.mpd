import test::assert
import file::File
import file::READ
import file::WRITE
import memory::Allocator

@test
fun file_open()
    var f: File
    assert(f.open("resource/hello.txt", READ))
    assert(f.is_open())
    f.close()
    assert(f.is_open() == false)

@test
fun file_open_missing()
    var f: File
    assert(f.open("resource/missing.txt", READ) == false)
    assert(f.is_open() == false)

@test
fun file_read_bytes()
    var alloc: Allocator
    alloc.init(256)
    var buf := alloc.allocate_array<u8>(32)
    var f: File
    f.open("resource/hello.txt", READ)
    val n := f.read_bytes(buf)
    assert(n > 0)
    f.close()

@test
fun file_read_line()
    var alloc: Allocator
    alloc.init(256)
    var buf := alloc.allocate_array<u8>(64)
    var f: File
    f.open("resource/lines.txt", READ)
    val n := f.read_line(buf)
    assert(n > 0)
    assert(n < 64)
    f.close()

@test
fun file_read_all_lines()
    var alloc: Allocator
    alloc.init(256)
    var buf := alloc.allocate_array<u8>(64)
    var f: File
    f.open("resource/lines.txt", READ)
    var count: u32 = 0
    while f.read_line(buf) > 0
        count += 1
    assert(count == 3)
    f.close()

@test
fun file_tell_seek()
    var alloc: Allocator
    alloc.init(256)
    var buf := alloc.allocate_array<u8>(5)
    var f: File
    f.open("resource/hello.txt", READ)
    assert(f.tell() == 0)
    f.read_bytes(buf)       // reads "Hello"
    assert(f.tell() == 5)
    f.seek(0)
    assert(f.tell() == 0)
    f.close()

@test
fun file_write_read()
    var alloc: Allocator
    alloc.init(256)
    var buf := alloc.allocate_array<u8>(16)
    var f: File
    f.open(".micro-panda/test/file_write_output.txt", WRITE)
    f.write_str("hello")
    f.close()
    f.open(".micro-panda/test/file_write_output.txt", READ)
    val n := f.read_bytes(buf)
    assert(n == 5)
    f.close()
