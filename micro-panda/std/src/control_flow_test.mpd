import test::assert

// ── if / else ─────────────────────────────────────────────────────────────────

@test
fun if_true()
    var x: i32 = 0
    if 1 == 1
        x = 1
    assert(x == 1)

@test
fun if_false()
    var x: i32 = 0
    if 1 == 2
        x = 1
    assert(x == 0)

@test
fun if_else()
    var x: i32 = 0
    if 1 == 2
        x = 1
    else
        x = 2
    assert(x == 2)

@test
fun if_else_if()
    var x: i32 = 0
    var v: i32 = 2
    if v == 1
        x = 10
    else if v == 2
        x = 20
    else
        x = 30
    assert(x == 20)

@test
fun nested_if()
    var x: i32 = 0
    if 1 == 1
        if 2 == 2
            x = 42
    assert(x == 42)

// ── while ─────────────────────────────────────────────────────────────────────

@test
fun while_loop()
    var i: i32 = 0
    var sum: i32 = 0
    while i < 5
        sum += i
        i++
    assert(sum == 10)

@test
fun while_not_entered()
    var x: i32 = 99
    while 1 == 2
        x = 0
    assert(x == 99)

// ── for range ─────────────────────────────────────────────────────────────────

@test
fun for_range_sum()
    var sum: i32 = 0
    for i in range(0, 5)
        sum += i
    assert(sum == 10)   // 0+1+2+3+4

@test
fun for_range_empty()
    var count: i32 = 0
    for i in range(5, 5)
        count++
    assert(count == 0)

@test
fun for_range_variable()
    var last: i32 = -1
    for i in range(0, 4)
        last = i
    assert(last == 3)

// ── for in (fixed array) ──────────────────────────────────────────────────────

@test
fun for_in_fixed_array()
    var arr: i32[5]
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4
    arr[4] = 5
    var sum: i32 = 0
    for item in arr
        sum += item
    assert(sum == 15)

@test
fun for_in_fixed_array_index()
    var arr: i32[3]
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    var last_idx: i32 = -1
    for idx, item in arr
        last_idx = i32(idx)
    assert(last_idx == 2)

// ── for in (slice) ────────────────────────────────────────────────────────────

fun sum_slice(s: i32[]) i32
    var total: i32 = 0
    for item in s
        total += item
    return total

@test
fun for_in_slice()
    var arr: i32[4]
    arr[0] = 1
    arr[1] = 2
    arr[2] = 3
    arr[3] = 4
    val s: i32[] = {&arr[0], u32(4)}
    assert(sum_slice(s) == 10)

fun find_index(s: i32[], target: i32) i32
    for idx, item in s
        if item == target
            return i32(idx)
    return -1

@test
fun for_in_slice_index()
    var arr: i32[3]
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    val s: i32[] = {&arr[0], u32(3)}
    assert(find_index(s, 20) == 1)
    assert(find_index(s, 99) == -1)

// ── break ─────────────────────────────────────────────────────────────────────

@test
fun break_while()
    var i: i32 = 0
    while i < 100
        if i == 5
            break
        i++
    assert(i == 5)

@test
fun break_for_range()
    var found: i32 = -1
    for i in range(0, 10)
        if i == 6
            found = i
            break
    assert(found == 6)

// ── continue ──────────────────────────────────────────────────────────────────

@test
fun continue_while()
    var i: i32 = 0
    var sum: i32 = 0
    while i < 10
        i++
        if i % 2 == 0
            continue
        sum += i       // sum odd numbers: 1+3+5+7+9 = 25
    assert(sum == 25)

@test
fun continue_for_range()
    var sum: i32 = 0
    for i in range(0, 10)
        if i % 2 == 0
            continue
        sum += i       // sum odd: 1+3+5+7+9 = 25
    assert(sum == 25)
